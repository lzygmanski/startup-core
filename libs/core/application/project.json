{
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "name": "core-application",
  "projectType": "library",
  "root": "libs/core/application",
  "sourceRoot": "libs/core/application/src",
  "tags": ["type:application", "scope:core"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec eslint libs/core/application/src --max-warnings=0"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsc --noEmit -p libs/core/application/tsconfig.lib.json"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec vitest run --config libs/core/application/vitest.config.ts"
      }
    }
  }
}
