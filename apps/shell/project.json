{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "shell",
  "projectType": "application",
  "root": "apps/shell",
  "sourceRoot": "apps/shell/src",
  "tags": ["type:app", "scope:core"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @startup-core/shell run dev"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/shell"],
      "options": {
        "command": "pnpm --filter @startup-core/shell run build"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec eslint apps/shell/src --max-warnings=0"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @startup-core/shell run typecheck"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @startup-core/shell run test"
      }
    }
  }
}
