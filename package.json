{
  "name": "startup-core",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "eslint . && nx run-many -t lint",
    "typecheck": "tsc --noEmit -p tsconfig.json && nx run-many -t typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "affected:typecheck": "nx affected -t typecheck",
    "cdk:synth": "cdk synth",
    "cdk:diff": "cdk diff",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "eslint --fix",
    "*.{ts,tsx,js,jsx,json,md,yml,yaml,css}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nx/eslint": "^23.0.1",
    "@nx/eslint-plugin": "^23.0.1",
    "@rsbuild/core": "^2.0.15",
    "@rsbuild/plugin-react": "^2.1.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "aws-cdk": "^2.1128.1",
    "aws-cdk-lib": "^2.260.0",
    "constructs": "^10.6.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "nx": "23.0.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-router": "^1.170.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  }
}
