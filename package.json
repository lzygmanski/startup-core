{
  "name": "startup-core",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "build": "nx run-many -t build",
    "test": "vitest run --config vitest.config.ts && nx run-many -t test",
    "lint": "eslint . && nx run-many -t lint",
    "typecheck": "tsc --noEmit -p tsconfig.json && nx run-many -t typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "affected:typecheck": "nx affected -t typecheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "eslint --fix",
    "*.{ts,tsx,js,jsx,json,md,yml,yaml,css}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nx/eslint": "^23.0.1",
    "@nx/eslint-plugin": "^23.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "nx": "23.0.1",
    "prettier": "^3.8.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
